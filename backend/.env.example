# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=miweb_db

# JWT (cambiar en producción)
JWT_SECRET=your-super-secret-key-change-in-production

# Server (API Go). Con React en Vite (5173): deja PORT=3000.
PORT=3000
#
# Frontend React (Vite): la URL del API se define en frontend-react/.env.development o al construir el front.
# Si el sitio estático y el API están en dominios distintos, en el BUILD del front hay que fijar p. ej.
#   VITE_BACKEND_URL=https://zcontable.gestionweb.cloud
# Sin eso, el navegador llama a /api en el mismo dominio que la web (p. ej. zcontables…) y el login falla (405, etc.).
# Ver frontend-react/.env.example

# Storage (carpeta física que se expone como /storage/**)
# Ejemplo Linux: /home/cloudpanel/htdocs/zcontable.gestionweb.cloud/storage
STORAGE_PATH=./storage

# Tukifac (opcional; también en Configuración del estudio en la app)
TUKIFAC_BASE_URL=
TUKIFAC_API_TOKEN=
# Rutas POST para emitir comprobantes (ajustar si tu instancia usa otra ruta)
TUKIFAC_POST_DOCUMENTS_PATH=/api/documents
TUKIFAC_POST_SALE_NOTE_PATH=/api/sale-note
